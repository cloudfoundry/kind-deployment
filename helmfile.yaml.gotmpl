---
helmDefaults:
  wait: true
  timeout: 600
  recreatePods: false
  force: false
  createNamespace: true
  syncArgs:
    - --hide-notes

environments:
  default:
    values:
      - ./values.yaml.gotmpl
      - ./versions.yaml
---
repositories:
  - name: nats
    url: https://nats-io.github.io/k8s/helm/charts
  - name: istio
    url: https://istio-release.storage.googleapis.com/charts
  - name: bitnami
    url: https://charts.bitnami.com/bitnami
  - name: cilium
    url: https://helm.cilium.io/
  - name: cloudfoundry-k8s
    oci: true
    url: ghcr.io/cloudfoundry/helm

releases:
  - name: cilium
    namespace: kube-system
    chart: {{ .Values.charts.cilium.url }}
    version: {{ .Values.charts.cilium.version }}
    values:
      - ./assets/values/cilium.yaml
    hooks:
      - events: ["postsync"]
        showlogs: true
        command: "/bin/sh"
        args:
          - "-c"
          - |
            echo "Waiting for nodes to become ready after CNI installation..."
            kubectl wait --for=condition=Ready nodes --all --timeout=300s

            corefile=$(kubectl -n kube-system get configmap coredns -o jsonpath='{.data.Corefile}' | sed '/kubernetes/i \
              rewrite name regex (.*)\\.127-0-0-1\\.nip\\.io istio-gateway-istio.{{ .Values.systemNamespace }}.svc.cluster.local answer auto\
            ')
            kubectl -n kube-system patch configmap coredns --type=json \
              -p="$(jq -n --arg cf "$corefile" '[{"op":"replace","path":"/data/Corefile","value":$cf}]')"
            kubectl -n kube-system rollout restart deployment/coredns

  - name: istio-base
    namespace: istio-system
    chart: {{ .Values.charts.istioBase.url }}
    version: {{ .Values.charts.istioBase.version }}
    needs:
      - kube-system/cilium
    values:
      - defaultRevision: minimal

  - name: istiod
    namespace: istio-system
    chart: {{ .Values.charts.istiod.url }}
    version: {{ .Values.charts.istiod.version }}
    needs:
      - istio-base
    values:
      - ./assets/values/istiod.yaml
    hooks:
      - events: ["presync"]
        showlogs: true
        command: "/bin/sh"
        args:
          - "-c"
          - |
            kubectl delete validatingwebhookconfiguration istio-validator-istio-system --ignore-not-found=true
  
  - name: base
    namespace: {{ .Values.systemNamespace }}
    chart: ./assets/base-chart
    needs:
      - kube-system/cilium
      - istio-system/istiod
    set:
      - name: caCert
        file: {{ .Values.certsDir }}/ca.crt
      - name: caKey
        file: {{ .Values.certsDir }}/ca.key
      - name: tlsCert
        file: {{ .Values.certsDir }}/all-in-one.crt
      - name: tlsKey
        file: {{ .Values.certsDir }}/all-in-one.key
    hooks:
      - events: ["presync"]
        showlogs: true
        command: "/bin/sh"
        args:
          - "-c"
          - |
            kubectl apply --server-side --filename assets/gateway-api.yaml

  - name: nats
    namespace: {{ .Values.systemNamespace }}
    chart: {{ .Values.charts.nats.url }}
    version: {{ .Values.charts.nats.version }}
    needs:
      - "{{ .Values.systemNamespace }}/base"
    values:
      - ./assets/values/nats.yaml

  - name: postgresql
    namespace: {{ .Values.systemNamespace }}
    chart: {{ .Values.charts.postgres.url }}
    version: {{ .Values.charts.postgres.version }}
    needs:
      - "{{ .Values.systemNamespace }}/base"
    values:
      - ./assets/values/postgresql.yaml
      - auth:
          password: {{ .Values.secrets.dbPassword }}

  - name: minio
    namespace: {{ .Values.systemNamespace }}
    chart: {{ .Values.charts.minio.url }}
    version: {{ .Values.charts.minio.version }}
    needs:
      - "{{ .Values.systemNamespace }}/base"
    values:
      - extraEnvVars:
          - name: MINIO_DOMAIN
            value: blobstore.127-0-0-1.nip.io
      - console:
          enabled: false
      - resourcesPreset: small
      - auth:
          rootPassword: {{ .Values.secrets.blobstorePassword }}
      - image:
          repository: bitnamilegacy/minio
      - global:
          security:
            allowInsecureImages: true
      - persistence:
          enabled: true
          size: 10Gi
          # Ensure blobstore data survives MinIO pod restarts.
          # Without persistence, resource pool SHA1 entries in PostgreSQL become stale:
          # CC says "I have click.tar.gz" -> client skips upload -> MinIO has no file ->
          # package assembly fails -> vendor/click not found in staging container.

  - name: loggregator-agent
    namespace: {{ .Values.systemNamespace }}
    chart: {{ .Values.charts.loggregatorAgent.url }}
    version: {{ .Values.charts.loggregatorAgent.version }}
    needs:
      - {{ .Values.systemNamespace }}/base
    values:
      - syslogBindingCache:
          enabled: true
          certificateSecret: all-in-one-tls
      - forwarderAgent:
          enabled: true
          certificateSecret: all-in-one-tls
      - loggregatorAgent:
          certificateSecret: all-in-one-tls
      - syslogAgent:
          certificateSecret: all-in-one-tls

  - name: gorouter
    namespace: {{ .Values.systemNamespace }}
    chart: {{ .Values.charts.routing.url }}
    version: {{ .Values.charts.routing.version }}
    needs:
      - {{ .Values.systemNamespace }}/base
      - {{ .Values.systemNamespace }}/nats
    values:
      - gorouter:
          enabled: true
          certificateSecret: all-in-one-tls
      - udpForwarder:
          certificateSecret: all-in-one-tls
      - gatewayObjects:
          enabled: false

  - name: tcp-routing
    namespace: {{ .Values.systemNamespace }}
    chart: {{ .Values.charts.routing.url }}
    version: {{ .Values.charts.routing.version }}
    installed: {{ .Values.installOptionalComponents }}
    needs:
      - loggregator-agent
      - locket
      - uaa
      - postgresql
    values:
      - routingApi:
          enabled: true
          sqldb:
            password: {{ .Values.secrets.dbPassword }}
            caCertificateSecret: all-in-one-tls
            skipSSLVerify: false
          certificateSecret: all-in-one-tls
          locketCertificateSecret: all-in-one-tls
          loggregatorCertificateSecret: all-in-one-tls
          uaaCertificateSecret: all-in-one-tls
      - tcpRouter:
          enabled: true
          oauthClientsSecret: {{ .Values.secrets.oauthClientsSecret }}
          certificateSecret: all-in-one-tls
      - gatewayObjects:
          enabled: false

  - name: loggregator
    namespace: {{ .Values.systemNamespace }}
    chart: {{ .Values.charts.loggregator.url }}
    version: {{ .Values.charts.loggregator.version }}
    installed: {{ .Values.installOptionalComponents }}
    needs:
      - {{ .Values.systemNamespace }}/base
    values:
      - loggregator:
          enabled: true
      - oauthClientsSecret: {{ .Values.secrets.oauthClientsSecret }}
      - doppler:
          certificateSecret: all-in-one-tls
      - reverseLogProxy:
          certificateSecret: all-in-one-tls
      - reverseLogProxyGateway:
          certificateSecret: all-in-one-tls
      - trafficcontroller:
          certificateSecret: all-in-one-tls
      - gatewayObjects:
          enabled: false

  - name: log-cache
    namespace: {{ .Values.systemNamespace }}
    chart: {{ .Values.charts.logCache.url }}
    version: {{ .Values.charts.logCache.version }}
    needs:
      - "{{ .Values.systemNamespace }}/base"
      - uaa
    values:
      - logCacheApi:
          certificateSecret: all-in-one-tls
      - logCacheBackend:
          certificateSecret: all-in-one-tls
      - gatewayObjects:
          enabled: false

  - name: uaa
    namespace: {{ .Values.systemNamespace }}
    chart: {{ .Values.charts.uaa.url }}
    version: {{ .Values.charts.uaa.version }}
    needs:
      - postgresql
      - {{ .Values.systemNamespace }}/base
    values:
      - ccAdminPassword: {{ .Values.secrets.ccAdminPassword }}
      - uaadb:
          password: {{ .Values.secrets.dbPassword }}
          caCertificateSecret: all-in-one-tls
          skipSSLVerify: false
      - oauthClientsSecret: {{ .Values.secrets.oauthClientsSecret }}
      - uaaAdminSecret: {{ .Values.secrets.uaaAdminSecret }}
      - certificateSecret: all-in-one-tls

  - name: credhub
    namespace: {{ .Values.systemNamespace }}
    chart: {{ .Values.charts.credhub.url }}
    version: {{ .Values.charts.credhub.version }}
    installed: {{ .Values.installOptionalComponents }}
    needs:
      - uaa
      - postgresql
    values:
      - caCertificateSecret: instance-identity
      - db:
          password: {{ .Values.secrets.dbPassword }}
          caCertificateSecret: all-in-one-tls
          skipSSLVerify: false

  - name: locket
    namespace: {{ .Values.systemNamespace }}
    chart: {{ .Values.charts.diego.url }}
    version: {{ .Values.charts.diego.version }}
    needs:
      - loggregator-agent
      - postgresql
    values:
      - locketdb:
          password: {{ .Values.secrets.dbPassword }}
          caCertificateSecret: all-in-one-tls
          skipSSLVerify: false
      - locket:
          enabled: true
          certificateSecret: all-in-one-tls
      - gatewayObjects:
          enabled: false

  - name: diego
    namespace: {{ .Values.systemNamespace }}
    chart: {{ .Values.charts.diego.url }}
    version: {{ .Values.charts.diego.version }}
    needs:
      - locket
      - uaa
      - loggregator-agent
    set:
      - name: sshProxyHostKey
        file: {{ .Values.certsDir }}/ssh_key
    values:
      - diegodb:
          password: {{ .Values.secrets.dbPassword }}
          caCertificateSecret: all-in-one-tls
          skipSSLVerify: false
      - diegoSSHCredentials: {{ .Values.secrets.diegoSSHCredentials }}
      - sshProxy:
          oauthClientsSecret: {{ .Values.secrets.oauthClientsSecret }}
      - auctioneer:
          enabled: true
          certificateSecret: all-in-one-tls
      - bbs:
          enabled: true
          certificateSecret: all-in-one-tls
      - fileserver:
          buildpacks: 
          {{ range $name, $buildpack := .Values.buildpacks }}
            {{ $name }}:
              image: {{ $buildpack.image }}
              tag: {{ $buildpack.tag }}
          {{ end }}
          enabled: true
      - sshProxy:
          enabled: true
          certificateSecret: all-in-one-tls
      - gatewayObjects:
          enabled: false

  - name: tps-watcher
    namespace: {{ .Values.systemNamespace }}
    chart: {{ .Values.charts.capi.url }}
    version: {{ .Values.charts.capi.version }}
    needs:
      - capi
    values:
      - tpsWatcher:
          enabled: true
          certificateSecret: all-in-one-tls
      - oauthClientsSecret: ""

  - name: route-emitter
    namespace: {{ .Values.systemNamespace }}
    chart: {{ .Values.charts.diego.url }}
    version: {{ .Values.charts.diego.version }}
    needs:
      - diego
      - nats
    {{ if .Values.installOptionalComponents }}
      - cf-networking
    {{ end }}
    values:
      - diegoSSHCredentials: ""
      - sshProxyHostKey: ""
      - routeEmitter:
          enabled: true
          certificateSecret: all-in-one-tls
          routingApi:
            enabled: {{ .Values.installOptionalComponents }}
            certificateSecret: all-in-one-tls
          oauthClientsSecret: {{ .Values.secrets.oauthClientsSecret }}
          natsCertificateSecret: all-in-one-tls
          loggregatorCertificateSecret: all-in-one-tls
          bbsCertificateSecret: all-in-one-tls
          locketCertificateSecret: all-in-one-tls
          uaaCertificateSecret: all-in-one-tls
          enableInternalEmitter: {{ .Values.installOptionalComponents }}
          enableTcpEmitter: {{ .Values.installOptionalComponents }}

  - name: k8s-rep
    namespace: {{ .Values.systemNamespace }}
    chart: {{ .Values.charts.k8sRep.url }}
    version: {{ .Values.charts.k8sRep.version }}
    needs:
      - diego
    set:
      - name: caCertificate
        file: {{ .Values.certsDir }}/ca.crt
    values:
      - stacks:
          cflinuxfs4: {{ .Values.stacks.cflinuxfs4.image }}:{{ .Values.stacks.cflinuxfs4.tag }}
      - workloadsNamespace: {{ .Values.workloadsNamespace }}
      - containerProxyVerifySubjectAltName:
          - gorouter
          - ssh-proxy
          - cf-tcp-router
      - loggregator:
          certificateSecret: all-in-one-tls
      - locket:
          certificateSecret: all-in-one-tls

    hooks:
      - events: ["presync"]
        showlogs: true
        command: "/bin/sh"
        args:
          - "-c"
          - |
            kubectl create namespace {{ .Values.workloadsNamespace }} --dry-run=client -o yaml | kubectl apply -f -
            kubectl create configmap trusted-system-certs --namespace {{ .Values.workloadsNamespace }} --from-file=trusted-ca-1.crt={{ .Values.certsDir }}/ca.crt --dry-run=client -o yaml | kubectl apply -f -

  - name: capi
    namespace: {{ .Values.systemNamespace }}
    chart: {{ .Values.charts.capi.url }}
    version: {{ .Values.charts.capi.version }}
    needs:
      - minio
      - diego
      - postgresql
    values:
      - gatewayObjects:
          enabled: false
      - cloudController:
          enabled: true
          certificateSecret: all-in-one-tls
          blobstore:
            storage_cli:
              aws_secret_access_key: {{ .Values.secrets.blobstorePassword }}
          sshProxyKeyFingerprint: {{ .Values.secrets.sshProxyKeyFingerprint | quote }}
          enableCommaDelimitedDestinations: true
      - ccUploader:
          certificateSecret: all-in-one-tls
      - ccdb:
          password: {{ .Values.secrets.dbPassword }}
          caCertificateSecret: all-in-one-tls
          skipSSLVerify: false
      - oauthClientsSecret: {{ .Values.secrets.oauthClientsSecret }}

  - name: nfs-volume
    namespace: {{ .Values.systemNamespace }}
    chart: {{ .Values.charts.nfsVolume.url }}
    version: {{ .Values.charts.nfsVolume.version }}
    installed: {{ .Values.installOptionalComponents }}
    needs:
      - capi
    values:
      - nfsbroker:
          enabled: true
          certificateSecret: all-in-one-tls
          oauthClientsSecret: {{ .Values.secrets.oauthClientsSecret }}
      - nfsv3driver:
          enabled: true

  - name: cf-networking
    namespace: {{ .Values.systemNamespace }}
    chart: {{ .Values.charts.cfNetworking.url }}
    version: {{ .Values.charts.cfNetworking.version }}
    installed: {{ .Values.installOptionalComponents }}
    needs:
      - capi
      - uaa
      - locket
      - loggregator-agent
    values:
      - policyServer:
          enabled: true
          networkpolicydb:
            password: {{ .Values.secrets.dbPassword }}
            caCertificateSecret: all-in-one-tls
            skipSSLVerify: false
          oauthClientsSecret: {{ .Values.secrets.oauthClientsSecret }}
          certificateSecret: all-in-one-tls
      - serviceDiscoveryController:
          enabled: true
          certificateSecret: all-in-one-tls
      - boshDnsAdapter:
          enabled: true
          certificateSecret: all-in-one-tls
      - boshDns:
          certificateSecret: all-in-one-tls
      - gatewayObjects:
          enabled: false

  - name: policy-agent
    namespace: {{ .Values.systemNamespace }}
    chart: {{ .Values.charts.policyAgent.url }}
    version: {{ .Values.charts.policyAgent.version }}
    installed: {{ .Values.installOptionalComponents }}
    needs:
      - cf-networking
    set:
      - name: certificateSecret
        value: all-in-one-tls
      - name: pollInterval
        value: "5s"
    hooks:
      - events: ["postsync"]
        showlogs: true
        command: "/bin/sh"
        args:
          - "-c"
          - |
            kubectl get configmap coredns -n kube-system -o jsonpath='{.data.Corefile}' | grep -q "apps.internal:53" || {
              echo "Patching CoreDNS to forward apps.internal to bosh-dns"
              BOSH_DNS_IP=$(kubectl get svc bosh-dns -n {{ .Values.systemNamespace }} -o jsonpath='{.spec.clusterIP}')
              COREFILE=$(kubectl get configmap coredns -n kube-system -o jsonpath='{.data.Corefile}')
              printf '%s\n\n%s' "apps.internal:53 {
                errors
                forward . ${BOSH_DNS_IP}
              }" "$COREFILE" | kubectl create configmap coredns -n kube-system --from-file=Corefile=/dev/stdin --dry-run=client -o yaml | kubectl apply -f -
              kubectl rollout restart deployment coredns -n kube-system
            }
